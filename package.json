{
  "name": "@laurentenhoor/devclaw",
  "version": "1.6.1",
  "description": "Multi-project dev/qa pipeline orchestration for OpenClaw",
  "type": "module",
  "license": "MIT",
  "author": "Lauren ten Hoor <laurentenhoor@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/laurentenhoor/devclaw.git"
  },
  "bugs": {
    "url": "https://github.com/laurentenhoor/devclaw/issues"
  },
  "homepage": "https://github.com/laurentenhoor/devclaw#readme",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "dev-pipeline",
    "orchestration",
    "gitlab",
    "github",
    "multi-project"
  ],
  "engines": {
    "node": ">=22"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "defaults/",
    "roles/",
    "docs/",
    "openclaw.plugin.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node build.mjs",
    "check": "tsc --noEmit",
    "watch": "tsc --noEmit --watch",
    "prepublishOnly": "npm run build",
    "test": "tsx --test $(find lib -name \"*.test.ts\" ! -name \"projects.test.ts\" ! -name \"pipeline.e2e.test.ts\" ! -name \"health.test.ts\")",
    "lint": "npm run check",
    "format": "prettier --write README.md .github/workflows/*.yml package.json openclaw.plugin.json",
    "format-check": "prettier --check README.md .github/workflows/*.yml package.json openclaw.plugin.json",
    "prepare": "husky",
    "validate": "npm run format-check && npm run lint && npm run build && npm run test"
  },
  "peerDependencies": {
    "openclaw": "^2026.2.21"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "cockatiel": "^3.2.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.9.3",
    "yaml": "^2.8.2",
    "unique-names-generator": "^4.7.1",
    "zod": "^4.3.6",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "tsx": "^4.20.5",
    "prettier": "^3.6.2"
  },
  "lint-staged": {
    "*.{md,json,yml,yaml}": [
      "prettier --write"
    ]
  }
}
